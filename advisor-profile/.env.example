# =============================================================================
# advisor-profile environment variables
# Copy to .env.local and fill in. Values are validated at startup (lib/env.ts).
# =============================================================================

# --- Required (app will not boot without these) -----------------------------
# Supabase project URL and keys.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key (server-only; NEVER expose to the client / no NEXT_PUBLIC_ prefix).
SUPABASE_SERVICE_ROLE_KEY=

# --- Production-recommended (warned about at boot if missing) ----------------
# Shared secret required by all cron routes (Authorization: Bearer <CRON_SECRET>).
CRON_SECRET=
# Upstash Redis for rate limiting. If unset in production, rate limiting fails
# closed (returns 503) on protected routes.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Google Gemini API key for the AI concierge. If unset in production, /api/chat
# returns 503 (instead of the demo/mock stream).
GOOGLE_GENERATIVE_AI_API_KEY=
# Resend transactional email. If unset, emails are skipped (logged, not sent).
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# HMAC secret enabling the funnel-token gate on anonymous LLM endpoints.
# When set, /api/chat, /api/synthesize-brief, and /api/match-advisors* require a
# valid token issued by /api/funnel-token.
FUNNEL_TOKEN_SECRET=
# HMAC secret binding readiness scores to the server. When set, match endpoints
# reject client-forged readiness scores. Falls back to FUNNEL_TOKEN_SECRET.
READINESS_SIGNING_SECRET=

# --- Optional / feature configuration ----------------------------------------
# Override the default Gemini model id.
GEMINI_CONCIERGE_MODEL=
# SEON fraud-vetting integration.
SEON_API_KEY=
SEON_API_URL=
# 'true' = always fail open, 'false' = always fail closed.
# Unset = fail open outside production, fail closed (quarantine) in production.
SEON_FAIL_OPEN=
# Fraud score (0-100) at/above which a lead is hard-blocked (default 70).
SEON_FRAUD_BLOCK_THRESHOLD=
# Lead vetting pass threshold (default 55).
VETTING_PASS_THRESHOLD=
# Master switch for the lead-vetting pipeline (default true).
LEAD_VETTING_ENABLED=
# Delay before the post-approval email is sent, in minutes (default 15).
EMAIL_DELAY_MINUTES=
# When true, admin overrides send the email immediately (default false).
ADMIN_OVERRIDE_EMAIL_IMMEDIATE=
# Comma-separated admin email allowlist (in addition to account_role='admin').
ADMIN_EMAILS=
# Public site URL used to build absolute links (falls back to VERCEL_URL).
NEXT_PUBLIC_SITE_URL=
# Default agency name shown on the login screen (default AEROTOUR).
NEXT_PUBLIC_DEFAULT_AGENCY_NAME=
# Unsplash access key for city imagery (optional).
NEXT_PUBLIC_UNSPLASH_ACCESS_KEY=

# --- Sentry / observability (optional) ---------------------------------------
# When set, server errors are reported to Sentry (see lib/observability.ts).
SENTRY_DSN=
