# Copy to advisor-profile/.env.test and fill in values (do not commit secrets).
# .env.test is loaded by playwright.config.ts alongside .env.local.

PLAYWRIGHT_BASE_URL=http://localhost:3000

NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Must match the running Next.js app
CRON_SECRET=

# Supabase Auth → Phone → Test phone numbers (E.164 without +)
E2E_MOCK_PHONE=919205025389
E2E_MOCK_OTP=123456

# Optional: affluence zip for phone verification step
E2E_RESIDENTIAL_ZIP=110001

# Vetting / email (playwright webServer also sets defaults)
LEAD_VETTING_ENABLED=true
EMAIL_DELAY_MINUTES=0
SEON_FAIL_OPEN=true

# Optional: Resend (required for cron to actually send email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Optional: Mailtrap inbox API for email assertion
MAILTRAP_API_TOKEN=
MAILTRAP_INBOX_ID=
